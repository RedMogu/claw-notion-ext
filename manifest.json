{
  "manifest_version": 3,
  "name": "Claw Notion Ext",
  "version": "1.0.17",
  "description": "Integration with OpenClaw Gateway for Notion",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.notion.so/*",
    "*://docs.google.com/*",
    "http://*/*",
    "https://*/*",
    "ws://*/*",
    "wss://*/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.notion.so/*", "*://docs.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
